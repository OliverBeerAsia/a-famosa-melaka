{
  "name": "a-famosa-streets-of-golden-melaka",
  "version": "0.2.0",
  "description": "A pixel-art adventure RPG set in Portuguese Melaka circa 1580",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "vite",
    "electron": "npm run build && electron .",
    "electron:dev": "electron . --dev",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder --mac --win --linux",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate:art": "node tools/validate-gameplay-assets.cjs",
    "generate:character-sheets": "node tools/generate-character-sheets-v2.cjs",
    "generate:tiles": "node tools/ultima8-graphics/generate-all.cjs",
    "generate:iso-tiles": "node tools/generate-iso-tiles.cjs",
    "generate:particles": "node tools/generate-particle-sprites.cjs",
    "generate:ui": "node tools/generate-ui-assets.cjs",
    "generate:scene-variants": "node tools/generate-time-of-day-variants.cjs",
    "generate:animated-objects": "node tools/ultima8-graphics/animated-objects.cjs",
    "generate:all-art": "node tools/ultima8-graphics/generate-all.cjs && node tools/ultima8-graphics/animated-objects.cjs && node tools/generate-character-sheets-v2.cjs && node tools/generate-iso-tiles.cjs && node tools/generate-particle-sprites.cjs && node tools/generate-ui-assets.cjs",
    "generate:graphics": "npm run generate:all-art && npm run generate:scene-variants",
    "fix:assets": "node tools/fix-gameplay-assets.cjs",
    "legacy:start": "webpack serve --mode development",
    "legacy:build": "webpack --mode production"
  },
  "keywords": [
    "phaser",
    "react",
    "rpg",
    "pixel-art",
    "adventure",
    "melaka",
    "historical"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "phaser": "^3.70.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0",
    "framer-motion": "^10.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^9.1.3",
    "canvas": "^3.2.0",
    "copy-webpack-plugin": "^11.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "overrides": {
    "@electron/asar": {
      "minimatch": "3.1.4"
    },
    "@electron/universal": {
      "minimatch": "3.1.4"
    },
    "app-builder-lib": {
      "minimatch": "5.1.8"
    },
    "config-file-ts": {
      "glob": {
        "minimatch": "9.0.7"
      }
    },
    "dir-compare": {
      "minimatch": "3.1.4"
    },
    "filelist": {
      "minimatch": "5.1.8"
    },
    "glob": {
      "minimatch": "3.1.4"
    },
    "readdir-glob": {
      "minimatch": "5.1.8"
    },
    "test-exclude": {
      "minimatch": "3.1.4"
    }
  },
  "build": {
    "appId": "com.afamosa.melaka",
    "productName": "A Famosa Streets of Golden Melaka",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game"
    },
    "dmg": {
      "title": "${productName}",
      "backgroundColor": "#0a0806"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
